---
interface Heading {
    depth: number;
    slug: string;
    text: string;
}

interface TOCHeading extends Heading {
    subheadings: TOCHeading[];
    prefix?: string;
}

function buildTOC(headings: Heading[]) {
    const toc: TOCHeading[] = [];
    const parentHeadings = new Map();
    const numbering = new Map();
    headings.forEach((h: Heading) => {
        const heading: TOCHeading = { ...h, subheadings: [] };
        parentHeadings.set(heading.depth, heading);
        numbering.set(heading.depth, (numbering.get(heading.depth) || 0) + 1);
        // Reset numbering for deeper levels
        for (let i = heading.depth + 1; i <= 6; i++) numbering.set(i, 0);
        const prefix = Array.from(numbering.entries())
            .filter(([, num]) => num > 0)
            .map(([, num]) => num)
            .join(".");
        heading.prefix = prefix;
        toc.push(heading);
    });
    headings = toc;

    return toc;
}

const { headings, title } = Astro.props;
---

<script>
    function tocInit() {
        const tocLinks = Array.from(
            document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
        );
        if (tocLinks.length === 0) return;

        // Derive headings directly from TOC link hrefs — scoped to article only,
        // and IDs are guaranteed to match (no text-matching needed).
        const headings = tocLinks
            .map((link) => document.getElementById(link.getAttribute("href")!.slice(1)))
            .filter((el): el is HTMLElement => el !== null);
        if (headings.length === 0) return;

        function setActive(index: number) {
            tocLinks.forEach((link, i) => {
                link.classList.toggle("toc-active-link", i === index);
                link.classList.toggle("toc-link", i !== index);
            });
        }

        // Initialize: first link active before observer fires
        setActive(0);

        const visible = new Set<HTMLElement>();
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) visible.add(entry.target as HTMLElement);
                    else visible.delete(entry.target as HTMLElement);
                });
                const firstVisible = headings.find((h) => visible.has(h));
                if (firstVisible) setActive(headings.indexOf(firstVisible));
            },
            { threshold: 1, rootMargin: "-5% 0% -5% 0%" },
        );

        headings.forEach((h) => observer.observe(h));
    }

    function manualActiveLinkInit() {
        const toc = document.querySelector("[data-toc]");
        toc?.addEventListener("click", (event) => {
            const targetLink = event.target as HTMLAnchorElement;
            const isNotTocLink = targetLink.tagName !== "A";
            if (isNotTocLink) return;
            const tocLinks = document.querySelector(".toc-manual-active-link");
            if (tocLinks) {
                tocLinks.classList.remove("toc-manual-active-link");
            }
            targetLink.classList.add("toc-manual-active-link");
            setTimeout(() => {
                targetLink.classList.remove("toc-manual-active-link");
            }, 1000);
        });
    }

    tocInit();
    manualActiveLinkInit();
</script>

<nav class="toc max-h-[80vh] overflow-y-auto hidden md:block">
    <p  style="color: #434343;">On This Page</p>
    <h5 class="font-bold toc-title" style="color: #CC543A;">{title}</h5>
    <ul>
        {
            buildTOC(headings).map(
                ({ depth, slug: headingSlug, text, prefix }) => {
                    const nestedHeadingClass = "text-sm";
                    const headingClass = "";
                    const depthClass = `${depth > 2 ? nestedHeadingClass : headingClass}`;
                    return (
                        <li class="p-0 m-0">
                            <div class={`toc-container ${depthClass}`}>
                                <a
                                    data-cy="toc-link"
                                    data-toc-link
                                    data-depth = {depth}
                                    class="block no-underline transition-opacity toc-item"
                                    href={`#${headingSlug}`}
                                >
                                    <div class="toc-number" style={`min-width: ${(depth - 1) * 2}rem; flex-shrink: 0; white-space: nowrap;`}>
                                        {prefix}
                                    </div>
                                    <div class="toc-link-title">
                                        {text}
                                    </div>
                                </a>
                            </div>
                        </li>
                    );
                },
            )
        }
    </ul>
</nav>

<style>
    .toc-link {
        opacity: 0.6;
        border-left: theme(borderWidth.2) solid transparent;
    }
    .toc-active-link {
        opacity: 1;
        color: #CC543A;
    }
    .toc-manual-active-link {
        opacity: 1;
    }
    ul {
        list-style-type: none;
        /* padding-left: 0; */
        /* margin: 0em; */
        /* margin-top: 1em; */
        padding-left: 0;
        margin: 0;
        white-space: normal;
    }
    .toc {
        flex-basis: 20%;
        position: sticky;
        top: 60px;
        height: max-content;
        text-wrap: pretty;
        overflow-x: auto;
        max-width: 100%;
        margin-bottom: 0;
        font-family: "Menlo", "Monaco", "Courier New", monospace;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .toc::-webkit-scrollbar {
        display: none;
    }
    .toc-title {
        font: 50pt;
        text-wrap: wrap;
    }
    h5 {
        font-size: 1.25em;
        margin: 0rem;
        margin-bottom: 0.5rem;
    }
    li {
        white-space: normal;
        margin: 0;
        padding: 0;
    }
    .toc-container {
        display: flex;
        flex-direction: row;
        gap: 10px;
        margin-bottom: 0.25rem;
    }
    .toc-item {
        display: flex;
        gap: 0.5em;
        margin-bottom: 0.25em;
        transition: color 0.3s;
    }
    .toc-number {
        min-width: 0.5em;
        text-align: right;
    }
</style>
